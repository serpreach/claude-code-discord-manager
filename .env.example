# ─── REQUIRED ───

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord user ID (right-click yourself → Copy User ID)
BOSS_DISCORD_ID=123456789012345678

# Default Claude model (opus, sonnet, or haiku)
CLAUDE_MODEL=sonnet

# ─── WORKER BOT SUPERVISION (optional) ───
# Set these if you have another bot (e.g. OpenClaw) you want Claude Code to supervise

# Worker bot's Discord user ID (set to 0 to disable supervision)
WORKER_BOT_ID=0

# Worker bot's display name (used in supervisor prompts)
WORKER_BOT_NAME=Worker

# Seconds between supervisor checks per channel
SUPERVISOR_COOLDOWN=30

# ─── AUTO-RESPOND CHANNELS (optional) ───
# Comma-separated channel IDs where Claude responds WITHOUT @mention
# Example: AUTO_RESPOND_CHANNELS=123456789,987654321
AUTO_RESPOND_CHANNELS=

# ─── PATHS (optional — defaults work for most setups) ───

# Directory for conversation logs and cross-channel context
SHARED_BRAIN_DIR=./shared-brain

# Bridge state file (sessions, admin list, message count)
STATE_FILE=./data/bridge_state.json

# Claude Code memory directory (optional — for MEMORY.md context injection)
# Example: MEMORY_DIR=/root/.claude/projects/-root/memory
MEMORY_DIR=

# Working directory for claude --print (CLAUDE.md auto-loads from cwd)
CLAUDE_CWD=/root

# Claude CLI response timeout in seconds (default: 1800 = 30 min)
CLAUDE_TIMEOUT=1800

# ─── TOOL EXECUTION (optional) ───
# Enable full tool access (Bash, Read, Edit, Write, etc.)
# IMPORTANT: Requires running as non-root user (see README)
# Set to "true" to enable --dangerously-skip-permissions flag
ENABLE_TOOLS=false
